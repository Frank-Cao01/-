{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "闪记",
  "version": "0.1.1",
  "identifier": "com.shanji.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "闪记",
        "url": "index.html#/",
        "width": 1180,
        "height": 760,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true,
        "shadow": true
      },
      {
        "label": "quick",
        "title": "闪记 · 快速记录",
        "url": "index.html#/quick",
        "width": 620,
        "height": 560,
        "minWidth": 480,
        "minHeight": 420,
        "maxWidth": 900,
        "maxHeight": 820,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Shanji",
    "category": "Productivity",
    "shortDescription": "快捷唤出的本地桌面备忘录",
    "longDescription": "闪记是一款轻量、快捷、本地优先的桌面备忘录软件。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "startMenuFolder": "闪记",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installerHooks": "windows/nsis-hooks.nsh"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
