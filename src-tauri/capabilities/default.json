{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-main",
  "description": "闪记主窗口与快速记录窗口的最小桌面权限",
  "windows": ["main", "quick"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "opener:default"
  ]
}
